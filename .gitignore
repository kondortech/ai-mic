# --- Project-specific ---
# Generated API artifacts (repo root only; Cloud Functions TS lives under firebase/functions/generated/)
/generated/

# Local agent / tooling (keep out of VCS unless you intend to share)
.agents/

# --- Environment & secrets (never commit) ---
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.p12
*.key
secrets/

# --- OS ---
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Editors & IDEs ---
# VS Code: not ignored by default so you can commit shared settings (e.g. settings.json).
# Uncomment the next line to ignore the whole folder (local-only workspace config).
# .vscode/

.idea/
*.iml
*.sublime-project
*.sublime-workspace
*.code-workspace
.project
.classpath
.settings/
*.swp
*.swo
*~

# --- Logs & temp ---
*.log
logs/
tmp/
temp/
.cache/
*.tmp
*.temp
*.bak
*.orig

# --- Node (if used at repo root or stray installs) ---
node_modules/

# --- Coverage & test artifacts ---
coverage/
.nyc_output/
*.lcov

# --- Build outputs (generic) ---
dist/
build/
out/

# --- Python (if any scripts/tools) ---
__pycache__/
*.py[cod]
.venv/
venv/
.Python

# --- Misc tooling ---
.turbo/
.vercel/

# vscode

.vscode/*