{
  "name": "ai-mic-api",
  "private": true,
  "scripts": {
    "generate": "npm run generate:ts && npm run generate:dart",
    "generate:ts": "openapi-typescript openapi.yaml -o generated/typescript/api.types.ts",
    "generate:dart": "openapi-generator-cli generate -i openapi.yaml -g dart -o generated/dart --additional-properties=pubName=ai_mic_api,pubVersion=1.0.0"
  },
  "devDependencies": {
    "openapi-typescript": "^7.4.0",
    "@openapitools/openapi-generator-cli": "^2.15.0"
  }
}
