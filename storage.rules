rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Recordings: each user can read/write only their own folder
    match /recordings/{userId}/{fileName} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Transcripts: written by Cloud Function; each user can read their own
    match /transcripts/{userId}/{fileName} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }
    // Temp path used by transcribe function (service account only)
    match /.transcribe_temp/{fileName} {
      allow read, write: if false;
    }
  }
}
