rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Inputs:
    // Storage layout: <userId>/inputs/<inputUuid>/raw_audio.mp4|raw_text.txt
    // Users may read both files, and write only raw_audio.mp4.
    match /{userId}/inputs/{inputUuid}/{fileName} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId && fileName == "raw_audio.mp4";
    }
    // Temp path used by transcribe function (service account only)
    match /.transcribe_temp/{fileName} {
      allow read, write: if false;
    }
  }
}
